{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["gru1"],
  "functions": {
    "api/ai.js": { "memory": 256, "maxDuration": 15 },
    "api/quotes.js": { "memory": 256, "maxDuration": 30 },
    "api/config.js": { "memory": 128, "maxDuration": 5 }
  },
  "rewrites": [
    { "source": "/config.js", "destination": "/api/config" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
